                    {lesson.id > 0 && (
                      <div className="flex bg-slate-100 p-1 rounded-lg w-full md:w-auto">
                        <button onClick={() => setLessonTab('video')} className={`flex-1 md:flex-none flex items-center justify-center gap-2 px-5 py-2 rounded-md text-sm font-bold transition-all ${lessonTab === 'video' ? 'bg-white text-blue-700 shadow-sm ring-1 ring-slate-200' : 'text-slate-600 hover:text-slate-900'}`}>
                          <Icon name="PlayCircle" size={16} /> Lecture
                        </button>
                        <button onClick={() => setLessonTab('reading')} className={`flex-1 md:flex-none flex items-center justify-center gap-2 px-5 py-2 rounded-md text-sm font-bold transition-all ${lessonTab === 'reading' ? 'bg-white text-blue-700 shadow-sm ring-1 ring-slate-200' : 'text-slate-600 hover:text-slate-900'}`}>
                          <Icon name="BookOpen" size={16} /> Reading
                        </button>
                        <button onClick={() => setLessonTab('questions')} className={`flex-1 md:flex-none flex items-center justify-center gap-2 px-5 py-2 rounded-md text-sm font-bold transition-all ${lessonTab === 'questions' ? 'bg-white text-blue-700 shadow-sm ring-1 ring-slate-200' : 'text-slate-600 hover:text-slate-900'}`}>
                          <Icon name="Edit3" size={16} /> {isHomeworkDone ? "Review" : "Homework"}
                        </button>
                      </div>
                    )}
                  </div>

                  <div className="p-8 max-w-4xl mx-auto w-full pb-32">
                    
                    {lessonTab === 'video' && lesson.id > 0 && (
                      <div className="animate-in slide-in-from-bottom-4">
                        <div className="aspect-video bg-slate-900 rounded-xl shadow-lg relative overflow-hidden group">
                          {lesson.youtubeId && lesson.youtubeId !== "YOUR_YOUTUBE_ID_HERE" ? (
                            <iframe className="absolute inset-0 w-full h-full" src={`https://www.youtube.com/embed/${lesson.youtubeId}`} title={`${lesson.title} Lecture`} frameBorder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowFullScreen></iframe>
                          ) : (
                            <div className="flex flex-col items-center justify-center h-full w-full p-4 text-center">
                              <Icon name="PlayCircle" size={64} className="text-white opacity-80 group-hover:scale-110 transition-transform cursor-pointer mb-4" />
                              <p className="text-white font-bold text-xl">Video Not Linked Yet</p>
                              <p className="text-slate-400 text-sm mt-2 max-w-md">Find <code>youtubeId: "YOUR_YOUTUBE_ID_HERE"</code> in the code for this lesson and replace it with your 11-character YouTube video ID.</p>
                            </div>
                          )}
                        </div>
                        <div className="mt-8 flex justify-center">
                          {progress.watchedVideos.includes(lesson.id) ? (
                            <div className="flex items-center gap-2 text-emerald-600 font-bold bg-emerald-50 px-6 py-3 rounded-full"><Icon name="CheckCircle" size={20}/> Lecture Marked as Completed</div>
                          ) : (
                            <button onClick={() => markVideoWatched(lesson.id)} className="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-full shadow-md transition-transform hover:-translate-y-0.5">Mark Lecture as Watched</button>
                          )}
                        </div>
                      </div>
                    )}

                    {lessonTab === 'reading' && (
                      <article className="prose prose-lg prose-slate max-w-none font-serif animate-in slide-in-from-bottom-4">
                        {lesson.reading.map((block, idx) => React.isValidElement(block) ? React.cloneElement(block, { key: idx }) : <p key={idx} className="leading-relaxed mb-6">{block}</p>)}
                        {lesson.id > 0 && (
                          <div className="mt-12 flex justify-center border-t border-slate-200 pt-8">
                             <button onClick={() => setLessonTab('questions')} className="bg-slate-900 text-white px-8 py-3 rounded-full font-bold flex items-center gap-2 hover:bg-slate-800">
                               Proceed to Homework <Icon name="ChevronRight" size={18}/>
                             </button>
                          </div>
                        )}
                      </article>
                    )}

                    {lessonTab === 'questions' && lesson.id > 0 && (
                      <div className="animate-in slide-in-from-bottom-4">
                        {isHomeworkDone && (
                          <div className="mb-8 bg-emerald-50 border border-emerald-200 rounded-xl p-6 flex gap-4 items-center">
                            <div className="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0"><Icon name="CheckCircle" size={28} className="text-emerald-600"/></div>
                            <div>
                              <h3 className="text-lg font-bold text-emerald-900">Homework Submitted!</h3>
                              <p className="text-emerald-700 text-sm font-medium">The correct answers have been revealed below to help you study for the final exam.</p>
                            </div>
                          </div>
                        )}

                        <div className="space-y-8">
                          {lesson.questions.map((q, idx) => {
                            const answer = progress.homeworkAnswers[q.id] || '';
                            return (
                              <div key={q.id} className={`bg-white rounded-xl shadow-sm border overflow-hidden ${isHomeworkDone ? 'border-slate-200 opacity-90' : 'border-slate-300'}`}>
                                <div className="p-6">
                                  <label className="text-lg font-bold text-slate-800 block mb-4 whitespace-pre-line">{q.prompt}</label>
                                  
                                  {q.type === 'tf' && (
                                    <div className="flex gap-3">
                                      {['True', 'False'].map(opt => (
                                        <button key={opt} disabled={isHomeworkDone} onClick={() => handleHWChange(q.id, opt)} className={`flex-1 py-3 px-4 rounded-lg border-2 font-bold transition-colors ${answer === opt ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-slate-200 text-slate-500'} ${isHomeworkDone ? 'cursor-not-allowed' : 'hover:border-blue-300'}`}>{opt}</button>
                                      ))}
                                    </div>
                                  )}

                                  {q.type === 'mc' && (
                                    <div className="flex flex-col gap-2">
                                      {q.options.map((opt, i) => {
                                        const letter = String.fromCharCode(97 + i);
                                        return (
                                          <button key={opt} disabled={isHomeworkDone} onClick={() => handleHWChange(q.id, opt)} className={`text-left py-3 px-4 rounded-lg border-2 font-semibold transition-colors ${answer === opt ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-slate-200 text-slate-600'} ${isHomeworkDone ? 'cursor-not-allowed' : 'hover:border-blue-300'}`}>
                                            <span className="font-bold mr-2 uppercase">{letter}.</span> {opt}
                                          </button>
                                        )
                                      })}
                                    </div>
                                  )}

                                  {(q.type === 'blank' || q.type === 'short') && (
                                    <textarea disabled={isHomeworkDone} value={answer} onChange={(e) => handleHWChange(q.id, e.target.value)} placeholder="Type answer..." rows={q.type==='blank'?1:3} className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg font-medium focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none disabled:opacity-70 disabled:bg-slate-100" />
                                  )}

                                  {q.type === 'match' && (
                                    <div>
                                      <div className="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-6 text-sm text-slate-600">
                                        <div className="font-semibold mb-2 flex items-center gap-2"><Icon name="AlertCircle" size={16}/> Options Bank:</div>
                                        <div className="grid grid-cols-2 md:grid-cols-3 gap-2">
                                          {q.right.map(opt => <div key={opt.id} className="truncate" title={opt.text}><span className="font-bold text-slate-800 mr-1">{opt.id}.</span> {opt.text}</div>)}
                                        </div>
                                      </div>
                                      <div className="grid gap-4 md:grid-cols-2">
                                        {q.left.map((leftItem) => (
                                          <div key={leftItem.id} className="flex flex-col sm:flex-row sm:items-center gap-3 p-3 bg-white border border-slate-100 rounded-lg shadow-sm">
                                            <div className="flex-1 text-slate-700 font-medium text-sm"><span className="text-slate-400 mr-2">{leftItem.id}.</span> {leftItem.text}</div>
                                            <select disabled={isHomeworkDone} value={(answer && answer[leftItem.id]) || ""} onChange={(e) => handleHWMatch(q.id, leftItem.id, e.target.value)} className="w-full sm:w-32 px-3 py-2 bg-slate-50 border border-slate-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm font-semibold">
                                              <option value="">Select...</option>
                                              {q.right.map(r => <option key={r.id} value={r.id}>{r.id}</option>)}
                                            </select>
                                          </div>
                                        ))}
                                      </div>
                                    </div>
                                  )}

                                  {isHomeworkDone && q.correct && (
                                    <div className="mt-4 bg-slate-100 rounded-lg p-4 border-l-4 border-emerald-500 flex flex-col">
                                      <span className="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1 flex items-center gap-1"><Icon name="CheckCircle" size={12}/> Correct Answer</span>
                                      {q.type === 'match' ? (
                                        <div className="text-sm font-medium text-slate-800 grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-1">
                                          {q.left.map(l => {
                                            const rightId = q.correct[l.id];
                                            const rightText = q.right.find(r => r.id === rightId)?.text;
                                            return <div key={l.id} className="truncate"><span className="text-emerald-600 font-bold">{l.id} &rarr; {rightId}</span> ({rightText})</div>
                                          })}
                                        </div>
                                      ) : (
                                        <span className="text-slate-800 font-semibold whitespace-pre-line">{q.correct}</span>
                                      )}
                                    </div>
                                  )}
                                </div>
                              </div>
                            );
                          })}
                        </div>
                        
                        {!isHomeworkDone && (
                          <div className="mt-10 flex justify-end">
                             <button onClick={() => submitHomework(lesson.id)} className="bg-emerald-600 hover:bg-emerald-700 text-white px-10 py-4 rounded-xl font-black shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 w-full sm:w-auto">Submit Homework</button>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                </div>
              );
            })()}

            {currentView === 'exam' && (
               <div className="p-8 max-w-4xl mx-auto animate-in fade-in duration-500 pb-32">
                  <header className="mb-8 text-center bg-slate-900 text-white p-12 rounded-2xl shadow-xl">
                    <Icon name="Award" size={48} className="mx-auto text-amber-500 mb-4" />
                    <h1 className="text-4xl font-black mb-2">Final Exam</h1>
                    <p className="text-slate-300 text-lg">{examData.subtitle}</p>
                  </header>

                  <div className="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
                    {!progress.examCompleted ? (
                      <div>
                        <p className="text-slate-600 mb-8 text-lg font-medium leading-relaxed text-center border-b pb-8">
                          The final exam consists of 45 questions drawn from the reading assignments and weekly homework. It accounts for 34% of your final grade.
                        </p>
                        
                        <div className="space-y-8">
                          {examData.questions.map((q, idx) => {
                            const answer = progress.examAnswers[q.id] || '';
                            return (
                              <div key={q.id} className="bg-white rounded-xl shadow-sm border border-slate-300 overflow-hidden">
                                <div className="p-6">
                                  <label className="text-lg font-bold text-slate-800 block mb-4">{q.prompt}</label>
                                  
                                  {q.type === 'tf' && (
                                    <div className="flex gap-3">
                                      {['True', 'False'].map(opt => (
                                        <button key={opt} onClick={() => handleExamChange(q.id, opt)} className={`flex-1 py-3 px-4 rounded-lg border-2 font-bold transition-colors ${answer === opt ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-slate-200 text-slate-500 hover:border-blue-300'}`}>{opt}</button>
                                      ))}
                                    </div>
                                  )}

                                  {q.type === 'mc' && (
                                    <div className="flex flex-col gap-2">
                                      {q.options.map((opt, i) => {
                                        const letter = String.fromCharCode(97 + i);
                                        return (
                                          <button key={opt} onClick={() => handleExamChange(q.id, letter)} className={`text-left py-3 px-4 rounded-lg border-2 font-semibold transition-colors ${answer === letter ? 'border-blue-500 bg-blue-50 text-blue-700' : 'border-slate-200 text-slate-600 hover:border-blue-300'}`}>
                                            <span className="font-bold mr-2 uppercase">{letter}.</span> {opt}
                                          </button>
                                        )
                                      })}
                                    </div>
                                  )}

                                  {(q.type === 'blank' || q.type === 'short') && (
                                    <textarea value={answer} onChange={(e) => handleExamChange(q.id, e.target.value)} placeholder="Type answer..." rows={q.type==='blank'?1:3} className="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg font-medium focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none" />
                                  )}

                                  {q.type === 'match' && (
                                    <div>
                                      <div className="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-6 text-sm text-slate-600">
                                        <div className="font-semibold mb-2 flex items-center gap-2"><Icon name="AlertCircle" size={16}/> Options Bank:</div>
                                        <div className="grid grid-cols-2 md:grid-cols-3 gap-2">
                                          {q.right.map(opt => <div key={opt.id} className="truncate" title={opt.text}><span className="font-bold text-slate-800 mr-1">{opt.id}.</span> {opt.text}</div>)}
                                        </div>
                                      </div>
                                      <div className="grid gap-4 md:grid-cols-2">
                                        {q.left.map((leftItem) => (
                                          <div key={leftItem.id} className="flex flex-col sm:flex-row sm:items-center gap-3 p-3 bg-white border border-slate-100 rounded-lg shadow-sm">
                                            <div className="flex-1 text-slate-700 font-medium text-sm"><span className="text-slate-400 mr-2">{leftItem.id}.</span> {leftItem.text}</div>
                                            <select value={(answer && answer[leftItem.id]) || ""} onChange={(e) => handleExamMatch(q.id, leftItem.id, e.target.value)} className="w-full sm:w-32 px-3 py-2 bg-slate-50 border border-slate-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm font-semibold">
                                              <option value="">Select...</option>
                                              {q.right.map(r => <option key={r.id} value={r.id}>{r.id}</option>)}
                                            </select>
                                          </div>
                                        ))}
                                      </div>
                                    </div>
                                  )}
                                </div>
                              </div>
                            );
                          })}
                        </div>

                        <div className="mt-12 flex justify-center">
                          <button onClick={submitExam} className="bg-amber-500 hover:bg-amber-600 text-slate-900 font-black px-12 py-4 rounded-full shadow-lg transition-transform hover:scale-105 flex items-center gap-2">
                            <Icon name="Check" size={20}/> Submit Final Exam
                          </button>
                        </div>
                      </div>
                    ) : (
                      <div className="bg-emerald-50 text-emerald-800 p-8 rounded-xl font-bold border border-emerald-200 text-center">
                        <Icon name="Award" size={48} className="mx-auto text-emerald-500 mb-4" />
                        <h3 className="text-2xl mb-2">Exam Completed!</h3>
                        <p className="font-medium text-emerald-700 mb-6">You scored {progress.examScore.toFixed(1)}%. Check your Dashboard for your total grade.</p>
                        <span className="text-sm font-medium text-emerald-600 bg-emerald-100 px-4 py-2 rounded-full inline-block">Integration Note: A webhook would now send your grade to Planning Center.</span>
                      </div>
                    )}
                  </div>
               </div>
            )}
          </main>
        </div>
      );
    }
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
